<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>com.dremio.plugins</groupId>
  <artifactId>dremio-kafka-connector</artifactId>
  <version>1.0.0-SNAPSHOT</version>
  <packaging>jar</packaging>

  <name>Dremio Apache Kafka Connector</name>
  <description>
    A Dremio storage plugin for Apache Kafka. Exposes Kafka topics as queryable tables
    with bounded snapshot scans. Supports raw and JSON schema modes with metadata
    columns (_topic, _partition, _offset, _timestamp, _key, _headers, _value_raw).
  </description>

  <developers>
    <developer>
      <id>mshainman</id>
      <name>Mark Shainman</name>
      <roles>
        <role>architect</role>
        <role>developer</role>
      </roles>
    </developer>
  </developers>

  <properties>
    <maven.compiler.source>11</maven.compiler.source>
    <maven.compiler.target>11</maven.compiler.target>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

    <dremio.version>26.0.5-202509091642240013-f5051a07</dremio.version>
    <arrow.version>18.1.1-20250709131625-66bbaf1fd7-dremio</arrow.version>
    <calcite.version>1.22.0-202501311721330426-8b30dab9</calcite.version>

    <!-- Apache Kafka Java client — 3.6.x is the latest stable LTS-compatible release.
         Compatible with Kafka brokers 0.10.x through 3.x (wide compatibility). -->
    <kafka.version>3.6.1</kafka.version>
  </properties>

  <repositories>
    <repository>
      <id>dremio-public</id>
      <name>Dremio Public Maven Repository</name>
      <url>https://maven.dremio.com/public/</url>
      <releases><enabled>true</enabled></releases>
      <snapshots><enabled>false</enabled></snapshots>
    </repository>
  </repositories>

  <dependencies>

    <!-- ================================================================
         DREMIO PLUGIN API (provided — Dremio supplies at runtime)
         ================================================================ -->
    <dependency>
      <groupId>com.dremio</groupId>
      <artifactId>dremio-sabot-kernel</artifactId>
      <version>${dremio.version}</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>com.dremio</groupId>
      <artifactId>dremio-common</artifactId>
      <version>${dremio.version}</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>com.dremio</groupId>
      <artifactId>dremio-sabot-kernel-proto</artifactId>
      <version>${dremio.version}</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>com.dremio</groupId>
      <artifactId>dremio-sabot-vector-tools</artifactId>
      <version>${dremio.version}</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>com.dremio</groupId>
      <artifactId>dremio-services-namespace</artifactId>
      <version>${dremio.version}</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>com.dremio</groupId>
      <artifactId>dremio-connector</artifactId>
      <version>${dremio.version}</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>com.dremio.plugin</groupId>
      <artifactId>dremio-plugin-common</artifactId>
      <version>${dremio.version}</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>com.dremio</groupId>
      <artifactId>dremio-sabot-logical</artifactId>
      <version>${dremio.version}</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>com.dremio</groupId>
      <artifactId>dremio-common-core</artifactId>
      <version>${dremio.version}</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>com.dremio.services</groupId>
      <artifactId>dremio-services-credentials</artifactId>
      <version>${dremio.version}</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>com.dremio</groupId>
      <artifactId>dremio-services-datastore</artifactId>
      <version>${dremio.version}</version>
      <scope>provided</scope>
    </dependency>

    <!-- Protostuff annotations -->
    <dependency>
      <groupId>io.protostuff</groupId>
      <artifactId>protostuff-api</artifactId>
      <version>1.4.4</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>io.protostuff</groupId>
      <artifactId>protostuff-core</artifactId>
      <version>1.4.4</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>io.protostuff</groupId>
      <artifactId>protostuff-runtime</artifactId>
      <version>1.4.4</version>
      <scope>provided</scope>
    </dependency>

    <!-- Arrow vectors (provided by Dremio) -->
    <dependency>
      <groupId>org.apache.arrow</groupId>
      <artifactId>arrow-vector</artifactId>
      <version>${arrow.version}</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>org.apache.arrow</groupId>
      <artifactId>arrow-memory-core</artifactId>
      <version>${arrow.version}</version>
      <scope>provided</scope>
    </dependency>

    <!-- SLF4J (provided by Dremio) -->
    <dependency>
      <groupId>org.slf4j</groupId>
      <artifactId>slf4j-api</artifactId>
      <version>1.7.36</version>
      <scope>provided</scope>
    </dependency>

    <!-- Calcite planning classes (provided by Dremio) -->
    <dependency>
      <groupId>org.apache.calcite</groupId>
      <artifactId>calcite-core</artifactId>
      <version>${calcite.version}</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>org.apache.calcite</groupId>
      <artifactId>calcite-linq4j</artifactId>
      <version>${calcite.version}</version>
      <scope>provided</scope>
    </dependency>

    <!-- javax.inject -->
    <dependency>
      <groupId>javax.inject</groupId>
      <artifactId>javax.inject</artifactId>
      <version>1</version>
      <scope>provided</scope>
    </dependency>

    <!-- Jackson (provided by Dremio) -->
    <dependency>
      <groupId>com.fasterxml.jackson.core</groupId>
      <artifactId>jackson-annotations</artifactId>
      <version>2.15.3</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>com.fasterxml.jackson.core</groupId>
      <artifactId>jackson-databind</artifactId>
      <version>2.15.3</version>
      <scope>provided</scope>
    </dependency>

    <!-- Guava (provided by Dremio) -->
    <dependency>
      <groupId>com.google.guava</groupId>
      <artifactId>guava</artifactId>
      <version>33.4.0-jre</version>
      <scope>provided</scope>
    </dependency>

    <!-- ================================================================
         APACHE AVRO — bundled in fat JAR; relocated to avoid version conflicts
         ================================================================ -->
    <dependency>
      <groupId>org.apache.avro</groupId>
      <artifactId>avro</artifactId>
      <version>1.11.3</version>
      <exclusions>
        <!-- These are all provided by Dremio at runtime -->
        <exclusion><groupId>com.fasterxml.jackson.core</groupId><artifactId>jackson-core</artifactId></exclusion>
        <exclusion><groupId>com.fasterxml.jackson.core</groupId><artifactId>jackson-databind</artifactId></exclusion>
        <exclusion><groupId>com.fasterxml.jackson.core</groupId><artifactId>jackson-annotations</artifactId></exclusion>
        <exclusion><groupId>org.slf4j</groupId><artifactId>slf4j-api</artifactId></exclusion>
        <exclusion><groupId>com.google.guava</groupId><artifactId>guava</artifactId></exclusion>
      </exclusions>
    </dependency>

    <!-- ================================================================
         APACHE KAFKA CLIENT — bundled in the fat plugin JAR.
         kafka-clients is self-contained; minimal transitive deps.
         ================================================================ -->
    <dependency>
      <groupId>org.apache.kafka</groupId>
      <artifactId>kafka-clients</artifactId>
      <version>${kafka.version}</version>
      <exclusions>
        <!-- Provided by Dremio -->
        <exclusion>
          <groupId>org.slf4j</groupId>
          <artifactId>slf4j-api</artifactId>
        </exclusion>
        <!-- Optional compression libs — exclude to keep JAR small;
             LZ4 / SNAPPY / ZSTD decompression is handled by kafka-clients
             internally only if those codecs are actually used by the broker. -->
        <exclusion>
          <groupId>org.lz4</groupId>
          <artifactId>lz4-java</artifactId>
        </exclusion>
        <exclusion>
          <groupId>org.xerial.snappy</groupId>
          <artifactId>snappy-java</artifactId>
        </exclusion>
        <exclusion>
          <groupId>com.github.luben</groupId>
          <artifactId>zstd-jni</artifactId>
        </exclusion>
      </exclusions>
    </dependency>

    <!-- ================================================================
         TEST
         ================================================================ -->
    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter</artifactId>
      <version>5.10.0</version>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>org.mockito</groupId>
      <artifactId>mockito-core</artifactId>
      <version>5.5.0</version>
      <scope>test</scope>
    </dependency>
    <dependency>
      <groupId>org.slf4j</groupId>
      <artifactId>slf4j-simple</artifactId>
      <version>1.7.36</version>
      <scope>test</scope>
    </dependency>

  </dependencies>

  <build>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.5.0</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals><goal>shade</goal></goals>
            <configuration>
              <shadedArtifactAttached>true</shadedArtifactAttached>
              <shadedClassifierName>plugin</shadedClassifierName>
              <relocations>
                <!--
                  Relocate kafka-clients to avoid classpath conflicts if any other
                  Dremio plugin or library ships kafka-clients at a different version.
                -->
                <relocation>
                  <pattern>org.apache.kafka</pattern>
                  <shadedPattern>shaded.org.apache.kafka</shadedPattern>
                </relocation>
                <relocation>
                  <pattern>org.apache.avro</pattern>
                  <shadedPattern>shaded.org.apache.avro</shadedPattern>
                </relocation>
              </relocations>
              <filters>
                <!-- Strip JAR signing files -->
                <filter>
                  <artifact>*:*</artifact>
                  <excludes>
                    <exclude>META-INF/*.SF</exclude>
                    <exclude>META-INF/*.DSA</exclude>
                    <exclude>META-INF/*.RSA</exclude>
                  </excludes>
                </filter>
                <!-- Exclude Jackson — provided by Dremio at runtime -->
                <filter>
                  <artifact>com.fasterxml.jackson.core:jackson-annotations</artifact>
                  <excludes><exclude>**</exclude></excludes>
                </filter>
                <filter>
                  <artifact>com.fasterxml.jackson.core:jackson-core</artifact>
                  <excludes><exclude>**</exclude></excludes>
                </filter>
                <filter>
                  <artifact>com.fasterxml.jackson.core:jackson-databind</artifact>
                  <excludes><exclude>**</exclude></excludes>
                </filter>
                <!-- Exclude SLF4J binders to preserve Dremio's logback configuration -->
                <filter>
                  <artifact>*:*</artifact>
                  <excludes>
                    <exclude>org/slf4j/impl/StaticLoggerBinder.class</exclude>
                    <exclude>org/slf4j/impl/StaticMDCBinder.class</exclude>
                    <exclude>org/slf4j/impl/StaticMarkerBinder.class</exclude>
                  </excludes>
                </filter>
              </filters>
            </configuration>
          </execution>
        </executions>
      </plugin>

      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <version>3.1.2</version>
        <configuration>
          <argLine>
            --add-opens java.base/java.lang=ALL-UNNAMED
            --add-opens java.base/java.io=ALL-UNNAMED
            -Dnet.bytebuddy.experimental=true
          </argLine>
        </configuration>
      </plugin>
    </plugins>
  </build>

</project>
