{
  "sourceType": "HUBSPOT",
  "metadataRefresh": {
    "isFileSystemSource": false,
    "isHiveSource": false
  },
  "form": {
    "sections": [
      {
        "name": "Authentication",
        "title": "Authentication",
        "elements": [
          {
            "type": "credentials",
            "propName": "config.accessToken",
            "label": "Private App Token",
            "tooltip": "HubSpot Private App access token. Create one in Settings → Integrations → Private Apps.",
            "size": "full"
          }
        ]
      },
      {
        "name": "Options",
        "title": "Advanced Options",
        "elements": [
          {
            "type": "number",
            "propName": "config.pageSize",
            "label": "Page Size",
            "placeholder": "100",
            "tooltip": "Records fetched per HubSpot API call (max 100)",
            "size": "half"
          },
          {
            "type": "number",
            "propName": "config.queryTimeoutSeconds",
            "label": "Query Timeout (seconds)",
            "placeholder": "60",
            "size": "half"
          },
          {
            "type": "checkbox",
            "propName": "config.includeArchived",
            "label": "Include archived records",
            "tooltip": "When enabled, archived (deleted) records are also returned",
            "size": "full"
          }
        ]
      }
    ]
  }
}
