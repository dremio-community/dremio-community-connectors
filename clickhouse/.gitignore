target/
*.class
*.iml
.idea/
.DS_Store

# Exclude all JARs but keep the jars/ directory (used by install.sh --prebuilt)
*.jar
!jars/

# The driver JAR is large (~23MB) and can be regenerated by the installer
# using --driver-fetch (downloads from Maven Central and patches automatically).
# We include it in jars/ as a convenience for users who want a one-step install,
# but exclude it from git to avoid bloating history.
# To regenerate manually:
#   curl -L https://repo1.maven.org/maven2/com/clickhouse/clickhouse-jdbc/0.4.6/clickhouse-jdbc-0.4.6-all.jar \
#        -o jars/clickhouse-jdbc-0.4.6-all.jar
#   zip -d jars/clickhouse-jdbc-0.4.6-all.jar META-INF/services/java.sql.Driver
jars/clickhouse-jdbc-0.4.6-all.jar
BUILD_JOURNAL.md
