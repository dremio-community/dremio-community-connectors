{
  "sourceType": "COSMOS_DB",
  "metadataRefresh": {
    "isFileSystemSource": false,
    "isHiveSource": false
  },
  "form": {
    "sections": [
      {
        "name": "Connection",
        "title": "Connection",
        "elements": [
          {
            "type": "text",
            "propName": "config.endpoint",
            "label": "Endpoint URL",
            "placeholder": "https://myaccount.documents.azure.com:443",
            "tooltip": "Use http://localhost:8081 for the local emulator",
            "size": "full"
          },
          {
            "type": "text",
            "propName": "config.database",
            "label": "Database",
            "placeholder": "mydb",
            "tooltip": "The Cosmos DB database name to expose as tables",
            "size": "half"
          },
          {
            "type": "credentials",
            "propName": "config.masterKey",
            "label": "Master Key",
            "tooltip": "Primary or secondary key from the Azure portal. Leave blank for local emulator.",
            "size": "full"
          }
        ]
      },
      {
        "name": "Options",
        "title": "Advanced Options",
        "elements": [
          {
            "type": "number",
            "propName": "config.pageSize",
            "label": "Page Size",
            "placeholder": "100",
            "tooltip": "Number of documents per API request",
            "size": "half"
          },
          {
            "type": "number",
            "propName": "config.schemaSampleSize",
            "label": "Schema Sample Size",
            "placeholder": "100",
            "tooltip": "Number of documents sampled to infer the schema for each container",
            "size": "half"
          },
          {
            "type": "number",
            "propName": "config.queryTimeoutSeconds",
            "label": "Query Timeout (seconds)",
            "placeholder": "120",
            "size": "half"
          }
        ]
      }
    ]
  }
}
